<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gyandow Collection</title>
  <style>
    body { font-family: Arial; margin:0; background:#f5f5f5; }
    header { background:#000; color:#fff; padding:15px; text-align:center; }
    .products { display:grid; grid-template-columns: repeat(auto-fit, minmax(200px,1fr)); gap:20px; padding:20px; }
    .card { background:#fff; padding:15px; border-radius:10px; box-shadow:0 2px 5px rgba(0,0,0,0.1); }
    .card img { width:100%; height:200px; object-fit:cover; }
    button { background:black; color:white; border:none; padding:10px; cursor:pointer; margin-top:10px; }
    .cart { position:fixed; top:10px; right:10px; background:#fff; padding:15px; border-radius:10px; }
  </style>
</head>
<body>

<header>
  <h1>Gyandow Collection</h1>
  <p>Men's Fashion & Shoes</p>
</header>

<div class="cart">
  <h3>Cart</h3>
  <ul id="cart-items"></ul>
  <p><b>Total:</b> GHS <span id="total">0</span></p>
</div>

<section class="products" id="product-list"></section>

<script>
  let products = [
    {name:"Men Suit", price:200, img:"https://via.placeholder.com/200"},
    {name:"Casual Shoes", price:120, img:"https://via.placeholder.com/200"}
  ];

  let cart = [];

  function displayProducts(){
    let list = document.getElementById("product-list");
    list.innerHTML = "";
    products.forEach((p, index)=>{
      list.innerHTML += `
        <div class="card">
          <img src="${p.img}" />
          <h3>${p.name}</h3>
          <p>GHS ${p.price}</p>
          <button onclick="addToCart(${index})">Add to Cart</button>
        </div>`;
    });
  }

  function addToCart(index){
    cart.push(products[index]);
    updateCart();
  }

  function updateCart(){
    let cartItems = document.getElementById("cart-items");
    let total = 0;
    cartItems.innerHTML = "";
    cart.forEach(item=>{
      total += item.price;
      cartItems.innerHTML += `<li>${item.name} - GHS ${item.price}</li>`;
    });
    document.getElementById("total").innerText = total;
  }

  displayProducts();
</script>

</body>
</html>
